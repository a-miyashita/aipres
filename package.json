{
  "name": "aipres",
  "version": "0.1.0",
  "description": "LLM-powered interactive Reveal.js presentation builder",
  "type": "module",
  "bin": {
    "aipres": "./dist/bin/aipres.js"
  },
  "files": [
    "dist/",
    "assets/"
  ],
  "scripts": {
    "dev": "tsx bin/aipres.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "prepack": "cp README.md README.dev.md && cp README.npm.md README.md",
    "postpack": "mv README.dev.md README.md",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "presentation",
    "reveal.js",
    "llm",
    "claude",
    "cli",
    "slides",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.7",
    "marked": "^12.0.0",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "reveal.js": "^5.1.0",
    "sanitize-html": "^2.17.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
